generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model PontoColeta {
  id                 String   @id @default(cuid())
  nome               String
  tipo               String
  endereco           String
  bairro             String
  telefone           String?
  latitude           Float?
  longitude          Float?
  recebeMedicamentos Boolean  @default(true)
  observacao         String?
  criadoEm           DateTime @default(now())
  atualizadoEm       DateTime @updatedAt
}